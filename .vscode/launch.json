{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "gmodel",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceRoot}/dots/db/tools/gmodel/gmodel.go",
      "args": ["-typeName=Notice"],
      "cwd": "${workspaceRoot}/sample/db/tools/model",
      "env": {
        "GOPACKAGE": "model",
        "GOFILE": "models_s.go",
      },
    },
    {
      "name": "wait_conn",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceRoot}/demo/wait_conn/main.go",
      "cwd": "${workspaceRoot}/demo/wait_conn/",
    },
    {
      "name": "sconfig",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceRoot}/samples/sconfig/",
      "cwd": "${workspaceRoot}/samples/sconfig",
      "args": ["-GenerateConfig=true"],
      // "dlvConfig": {
      //   "args": ["-GenerateConfig=true"],
      // },
    },
    {
      "name": "bls_server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceRoot}/samples/rpc/bls/bls_server/",
      "cwd": "${workspaceRoot}/samples/rpc/bls/bls_server",
      "args": ["-GenerateConfig=true"],
      // "dlvConfig": {
      //   "args": ["-GenerateConfig=true"],
      // },
    },
  ],
}
